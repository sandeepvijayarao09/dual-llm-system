# ── Required ──────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here

# ── Optional model overrides ───────────────────────────────────────────────────
# Large LLM (complex queries + personalization via profile injection)
# LARGE_MODEL=gemini-2.0-pro-exp

# Small LLM (classification, simple answers, context notes)
# SMALL_MODEL=gemini-2.5-flash-preview-04-17

# ── Routing thresholds ─────────────────────────────────────────────────────────
# Minimum confidence score to trust a "simple" routing (0.0–1.0)
# CONFIDENCE_THRESHOLD=0.75

# Token count above which we skip classification and go straight to Large LLM
# LARGE_INPUT_THRESHOLD=2000

# ── Timeouts (seconds) ─────────────────────────────────────────────────────────
# SMALL_LLM_TIMEOUT=60
# LARGE_LLM_TIMEOUT=120

# ── Profile Database ────────────────────────────────────────────────────────────
# SQLite file path (created automatically on first run)
# DB_PATH=profiles.db
