# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Optional overrides ─────────────────────────────────────────────────────────
# Ollama endpoint (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# Local model to use for the Small LLM (must be pulled via `ollama pull <model>`)
# Options: llama3.2:3b  phi3:mini  mistral  qwen2.5:3b  gemma2:2b
# SMALL_MODEL=llama3.2:3b

# Routing: min confidence score to trust a "simple" routing (0.0–1.0)
# CONFIDENCE_THRESHOLD=0.75

# Token count above which we skip classification and go straight to Large LLM
# LARGE_INPUT_THRESHOLD=2000

# Timeouts in seconds
# SMALL_LLM_TIMEOUT=60
# LARGE_LLM_TIMEOUT=120
